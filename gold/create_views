--========================================================================
--Stored procedure to creat consol bs and pl views based on the grid files
--these two views along with the trail balance will be the fact table in 
--power BI
--=========================================================================

Create or Replace procedure gold.consol_views()
Language plpgsql
As
$$
Begin

--======================================================================
--Create dim_entity_reporting to function as a filter option in power bi
--======================================================================

	Drop View if exists gold.dim_entity_reporting;
	Create view gold.dim_entity_reporting as
		Select
		common_name,
		vertical
		From gold.dim_entity_pack;

--==================================================================
--Consolidated balance sheet view
--==================================================================
	Drop view if exists gold.consol_bs;
	Create view gold.consol_bs as
		Select * from gold.fact_bs_act
		Union All
		Select * from gold.fact_bs_grid_ye
		Union All
		Select * from gold.fact_bs_budget
		Union All
		Select * from gold.fact_bs_budget_month;
--===================================================================
--Consolidated p&l view
--===================================================================

Drop view if exists gold.consol_pl;
	Create view gold.consol_pl as
		Select * from gold.fact_pl_act
		Union All
		Select * from gold.fact_pl_grid_ye
		Union All
		Select * from gold.fact_pl_budget
		Union All
		Select * from gold.fact_pl_budget_ytd;

End;
$$;

