--==================================================
--Create views in gold layer
--==================================================
Create or Replace procedure gold.create_views()
Language plpgsql
As
$$
Begin

--Create view gold.dim_annualized_factor

	Drop view if exists gold.dim_annualized_factor;
	Create view gold.dim_annualized_factor As
	Select 
		month_num,
		factor,
		month_name
	From silver.dim_annualized_factor;

--Create view gold.dim_ce_direction

	Drop view if exists gold.dim_ce_direction;
	Create view gold.dim_ce_direction as
	Select
		order_key,
		line_description,
		ce_direction,
		adjustment_items,
		ce_bucket,
		ce_sub_bucket,
		category
	From silver.dim_ce_direction;

--Create view dim_ce_method

	Drop view if exists gold.dim_ce_method;
	Create view gold.dim_ce_method as
	Select
		method_name
	From silver.dim_ce_method;

--Create view dim_ebit_direction

	Drop view if exists gold.dim_ebit_direction;
	Create view gold.dim_ebit_direction as
	Select
		order_key,
		line_description,
		common_name,
		ebit_direction,
		category
	From silver.dim_ebit_direction;

--Create view dim_entity_pack

	Drop view if exists gold.dim_entity_pack;
	Create view gold.dim_entity_pack as
	Select
		entity_key,
		entity_pack_name,
		common_name,
		vertical
	From silver.dim_entity_pack;

--Create view dim_entity_tb

	Drop view if exists gold.dim_entity_tb;
	Create view gold.dim_entity_tb as
	Select
		entity_key,
		entity_code,
		entity_name,
		common_name,
		vertical
	From silver.dim_entity_tb;

--Create view dim_gl_mapping

	Drop view if exists gold.dim_gl_mapping;
	Create view gold.dim_gl_mapping as
	Select
		gl_number,
		gl_description,
		gl_mapping,
		statement_map,
		statement_group,
		ce_direction,
		adjustment_items,
		ce_bucket,
		ce_sub_bucket
	From silver.dim_gl_mapping;

--Create view dim_period_reference

	Drop view if exists gold.dim_period_reference;
	Create view gold.dim_period_reference as
	Select
		periods,
		years,
		month_num,
		month_name,
		quarter,
		quarter_num,
		month_year,
		year_month_sort,
		year_month_name
	From silver.dim_period_reference;

--Create view dim_scenario_master

	Drop view if exists gold.dim_scenario_master;
	Create view gold.dim_scenario_master as
	Select
		scenario,
		months
	From silver.dim_scenario_master;

--Create view fact_bs_act

	Drop view if exists gold.fact_bs_act;
	Create view gold.fact_bs_act as
	Select
		ba.line_description,
		ba.pack_entity_name,
		ba.years,
		ba.scenario,
		ba.months,
		ba.amount_in_rupees,
		ba.ce_direction, 
		ba.adjustment_items, 
		ba.ce_bucket, 
		ba.ce_sub_bucket, 
		ba.month_year, 
		ba.category,
		ep.common_name as entity_name, --from dim_entity_pack
		ep.vertical,
		'ytd_annualized' as ce_method,--updated manually
		coalesce(ba.amount_in_rupees * ba.ce_direction, 0) as capital_employed,
		coalesce(ba.amount_in_rupees * ba.adjustment_items, 0) as adjustment_value
	From silver.fact_bs_act ba
	Left Join silver.dim_entity_pack ep
	On ba.pack_entity_name = ep.entity_pack_name
	Where ba.line_description Is Not Null
	Order by ba.month_year;

--Create view fact_bs_grid_ye

	Drop view if exists gold.fact_bs_grid_ye;
	Create view gold.fact_bs_grid_ye as
	Select
		bg.line_description,
		bg.pack_entity_name,
		bg.years,
		bg.scenario,
		bg.months,
		bg.amount_in_rupees,
		bg.ce_direction, 
		bg.adjustment_items, 
		bg.ce_bucket, 
		bg.ce_sub_bucket, 
		bg.month_year, 
		bg.category,
		ep.common_name as entity_name, --from dim_entity_pack
		ep.vertical,
		'year_end' as ce_method,--updated manually
		coalesce(bg.amount_in_rupees * bg.ce_direction, 0) as capital_employed,
		coalesce(bg.amount_in_rupees * bg.adjustment_items, 0) as adjustment_value
	From silver.fact_bs_grid_ye bg
	Left Join silver.dim_entity_pack ep
	On bg.pack_entity_name = ep.entity_pack_name
	Where bg.line_description Is Not Null
	Order by bg.month_year;

--Create view fact_pl_act

	Drop view if exists gold.fact_pl_act;
	Create view gold.fact_pl_act as
	Select
		pa.pack_entity_name,
		pa.line_description,
		pa.years,
		pa.scenario,
		pa.months,
		pa.amount_in_rupees,
		pa.ebit_direction,
		pa.year_month_name as month_year,
		pa.common_name as pl_line,
		pa.category,
		ep.common_name as entity_name, --entity common name from dim_entity_pack
		ep.vertical, -- vertical name from dim_entity_pack
		'ytd_annualized' as ce_method, --entered manually
		pa.factor as annualization_factor,
		coalesce(pa.amount_in_rupees * pa.ebit_direction * pa.factor, 0)as ebit_amount
	From silver.fact_pl_act pa
	Left Join silver.dim_entity_pack ep
	On pa.pack_entity_name = ep.entity_pack_name
	Where pa.line_description Is Not Null
	Order by pa.year_month_name;


--Create view fact_pl_grid_ye

	Drop view if exists gold.fact_pl_grid_ye;
	Create view gold.fact_pl_grid_ye as
	Select
		pg.pack_entity_name,
		pg.line_description,
		pg.years,
		pg.scenario,
		pg.amount_in_rupees,
		pg.ebit_direction,
		pg.year_month_name as month_year,
		pg.common_name as pl_line,
		pg.category,
		ep.common_name as entity_name, --entity common name from dim_entity_pack
		ep.vertical, -- vertical name from dim_entity_pack
		'year_end' as ce_method, --entered manually
		coalesce(pg.amount_in_rupees * pg.ebit_direction, 0)as ebit_amount
	From silver.fact_pl_grid_ye pg
	Left Join silver.dim_entity_pack ep
	On pg.pack_entity_name = ep.entity_pack_name
	Where pg.line_description Is Not Null
	Order by pg.year_month_name;

--Create view fact_trial_balance

	Drop view if exists gold.fact_trial_balance;
	create view gold.fact_trial_balance as
	Select
		tb.accounting_period,
		tb.entity_code,
		tb.entity_name,
		tb.account,
		tb.account_description,
		tb.period_activity,
		tb.ending_balance,
		tb.statement_map,
		tb.statement_group,
		tb.ce_direction,
		tb.adjustment_items,
		tb.ce_bucket,
		tb.ce_sub_bucket,
		tb.gl_mapping,
		etb.common_name,
		'denominator' as category,
		coalesce(tb.ending_balance * tb.ce_direction, 0)as capital_employed,
		coalesce(tb.ending_balance * tb.adjustment_items, 0)as adjustment_amount,
		'ytd_annualized' as ce_method
	From silver.fact_trial_balance tb
	Left join silver.dim_entity_tb etb
	On tb.entity_code = etb.entity_code
	Order by tb.accounting_period;
	
End;
$$;
