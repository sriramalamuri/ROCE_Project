--==================================================
--Load data into silver layer
--==================================================

Create or Replace procedure silver.load_silver()
language plpgsql
As $$
Begin

--Load data into silver.dim_scenario_master

	If to_regclass('silver.dim_scenario_master') Is Not Null Then
	Truncate Table silver.dim_scenario_master;
	End If;
	Insert Into silver.dim_scenario_master(
		scenario,
		months
	)
	Select 
		scenario,
		months
	From bronze.dim_scenario_master;

--Load data into silver.dim_annualized_factor

	If to_regclass('silver.dim_annualized_factor') Is Not Null Then
	Truncate Table silver.dim_annualized_factor;
	End If;
	Insert Into silver.dim_annualized_factor(
		month_num,
		factor,
		month_name
	)
	Select 
		month_num,
		factor,
		month_name
	From bronze.dim_annualized_factor;

--Load data into silver.dim_ce_direction

	If to_regclass('silver.dim_ce_direction') Is Not Null Then
	Truncate Table silver.dim_ce_direction;
	End If;
	Insert Into silver.dim_ce_direction(
		order_key,
		line_description,
		ce_direction,
		adjustment_items,
		ce_bucket,
		ce_sub_bucket,
		category
	)
	Select
		order_key,
		line_description,
		ce_direction,
		adjustment_items,
		ce_bucket,
		ce_sub_bucket,
		category
	From bronze.dim_ce_direction;

--Load data into silver.dim_ce_method

	If to_regclass('silver.dim_ce_method') Is Not Null Then
	Truncate Table silver.dim_ce_method;
	End if;
	Insert into silver.dim_ce_method(
		method_name
	)
	Select method_name
	From bronze.dim_ce_method;

--Load data into silver.dim_ebit_direction
	If to_regclass('silver.dim_ebit_direction') Is Not Null Then
	Truncate Table silver.dim_ebit_direction;
	End if;
	Insert Into silver.dim_ebit_direction(
		order_key,
		line_description,
		common_name,
		ebit_direction,
		category
	)
	Select
		order_key,
		line_description,
		common_name,
		ebit_direction,
		category
	From bronze.dim_ebit_direction;

--Load data into silver.dim_entity_pack

	If to_regclass('silver.dim_entity_pack') Is Not Null Then
	Truncate Table silver.dim_entity_pack;
	End If;
	Insert Into silver.dim_entity_pack(
		entity_key,
		entity_pack_name,
		common_name,
		vertical
	)
	Select 
		entity_key,
		entity_pack_name,
		common_name,
		vertical
	From bronze.dim_entity_pack;

--Load data into silver.dim_entity_tb

	If to_regclass('silver.dim_entity_tb') Is Not Null Then
	Truncate Table silver.dim_entity_tb;
	End If;
	Insert Into silver.dim_entity_tb(
		entity_key,
		entity_code,
		entity_name,
		common_name,
		vertical
	)
	Select
		entity_key,
		entity_code,
		entity_name,
		common_name,
		vertical
	From bronze.dim_entity_tb;

--Load data into silver.dim_gl_mapping

	If to_regclass('silver.dim_gl_mapping') Is Not Null Then
	Truncate Table silver.dim_gl_mapping;
	End If;
	Insert Into silver.dim_gl_mapping(
		gl_number,
		gl_description,
		gl_mapping,
		statement_map,
		statement_group,
		ce_direction,
		adjustment_items,
		ce_bucket,
		ce_sub_bucket
	)
	Select
		gl_number,
		gl_description,
		gl_mapping,
		statement_map,
		statement_group,
		ce_direction,
		adjustment_items,
		ce_bucket,
		ce_sub_bucket
	From bronze.dim_gl_mapping;
	
--Load data into silver.dim_period_reference

	If to_regclass('silver.dim_period_reference') Is Not Null Then
	Truncate Table silver.dim_period_reference;
	End If;
	Insert Into silver.dim_period_reference(
		periods,
		years,
		month_num,
		month_name,
		quarter,
		quarter_num,
		month_year,
		year_month_sort,
		year_month_name
	)
	Select
		periods,
		years,
		month_num,
		month_name,
		quarter,
		quarter_num,
		month_year,
		year_month_sort,
		year_month_name
	From bronze.dim_period_reference;

--Load data into silver.fact_bs_act

	If to_regclass('silver.fact_bs_act') Is Not Null Then
	Truncate Table silver.fact_bs_act;
	End If;
	Insert Into silver.fact_bs_act(
		line_description,
		pack_entity_name,
		years,
		scenario,
		months,
		amount_in_rupees,
		ce_direction, --this will come from join with dim_ce_direction
		adjustment_items, --this will come from join with dim_ce_direction
		ce_bucket, --this will come from join with dim_ce_direction
		ce_sub_bucket, --this will come from join with dim_ce_direction
		month_year, --this will be a concatenate of years and month column
		category --this will come from join with dim_ce_direction
	)
	Select
		ba.line_description as line_description,
		ba.pack_entity_name as pack_entity_name,
		ba.years as years,
		ba.scenario as scenario,
		ba.months as months,
		ba.amount_in_rupees as amount_in_rupees,
		cd.ce_direction as ce_direction,
		cd.adjustment_items as adjustment_items,
		cd.ce_bucket as ce_bucket,
		cd.ce_sub_bucket as ce_sub_bucket,
		ba.years || ba.months as month_year,
		cd.category as category		
	From bronze.fact_bs_act ba
	Left Join bronze.dim_ce_direction cd
	On ba.line_description = cd.line_description;

--Load data in silver.fact_bs_grid_ye
	If to_regclass('silver.fact_bs_grid_ye') Is Not Null Then
	Truncate Table silver.fact_bs_grid_ye;
	End If;
	Insert Into silver.fact_bs_grid_ye(
		line_description,
		pack_entity_name,
		years,
		scenario,
		months,
		amount_in_rupees,
		ce_direction, --this will come from join with dim_ce_direction
		adjustment_items, --this will come from join with dim_ce_direction
		ce_bucket, --this will come from join with dim_ce_direction
		ce_sub_bucket, --this will come from join with dim_ce_direction
		month_year, --this will be a concatenate of years column from this table and month column from scenario master
		category --this will come from join with dim_ce_direction
	)
	With fact_bs_grid_ye as(
	Select
		bg.line_description as line_description,
		bg.pack_entity_name as pack_entity_name,
		bg.years as years,
		bg.scenario as scenario,
		bg.months as months,
		bg.amount_in_rupees as amount_in_rupees,
		cd.ce_direction as ce_direction,
		cd.adjustment_items as adjustment_items, 
		cd.ce_bucket as ce_bucket, 
		cd.ce_sub_bucket as ce_sub_bucket, 
		--bg.month_year, 
		cd.category as category,
		sm.months as month_name
	From bronze.fact_bs_grid_ye bg
	Left Join bronze.dim_ce_direction cd
	On bg.line_description = cd.line_description
	Left Join bronze.dim_scenario_master sm
	On bg.scenario = sm.scenario
	)
	Select
		line_description,
		pack_entity_name,
		years,
		scenario,
		months, 
		amount_in_rupees, 
		ce_direction, 
		adjustment_items,
		ce_bucket, 
		ce_sub_bucket, 
		years||month_name as month_year, 
		category
	From fact_bs_grid_ye;


--Load data into silver.fact_pl_act

	If to_regclass('silver.fact_pl_act') Is Not Null Then
	Truncate Table silver.fact_pl_act;
	End If;
	Insert Into silver.fact_pl_act(
		pack_entity_name,
		line_description,
		custom_1,
		custom_2,
		years,
		scenario,
		months,
		amount_in_rupees,
		ebit_direction, --this will come from Left join on dim_ebit_direction
		common_name, --this will come from Left join on dim_ebit_direction
		category, --this will come from Left join on dim_ebit_direction
		year_month_name, --this will come from concat of years and months columns,
		factor
	)
	Select
		pa.pack_entity_name,
		pa.line_description,
		pa.custom_1,
		pa.custom_2,
		pa.years,
		pa.scenario,
		pa.months,
		pa.amount_in_rupees,
		ed.ebit_direction, --this will come from Left join on dim_ebit_direction
		ed.common_name, --this will come from Left join on dim_ebit_direction
		ed.category, --this will come from Left join on dim_ebit_direction
		pa.years||pa.months as year_month_name, --this will come from concat of years and months columns
		af.factor	
	From bronze.fact_pl_act pa
	Left Join bronze.dim_ebit_direction ed
	On pa.line_description = ed.line_description
	Left Join bronze.dim_annualized_factor af
	On pa.months = af.month_name;

--Load data into silver.fact_pl_grid_ye

	If to_regclass('silver.fact_pl_grid_ye') Is Not Null Then
	Truncate Table silver.fact_pl_grid_ye;
	End If;
	Insert Into silver.fact_pl_grid_ye(
		pack_entity_name,
		line_description,
		custom_1,
		custom_2,
		years,
		scenario,
		view_,
		amount_in_rupees,
		ebit_direction, --this will come from Left join on dim_ebit_direction
		common_name, --this will come from Left join on dim_ebit_direction
		category, --this will come from Left join on dim_ebit_direction
		year_month_name --this will come from concat of years from this table and months scenario_master
    )
	With fact_pl_ye as(
	Select
		pg.pack_entity_name as pack_entity_name,
		pg.line_description as line_description,
		pg.custom_1 as custom_1,
		pg.custom_2 as custom_2,
		pg.years as years,
		pg.scenario as scenario,
		pg.view_ as view_,
		pg.amount_in_rupees as amount_in_rupees,
		ed.ebit_direction as ebit_direction, 
		ed.common_name as common_name, 
		ed.category as category,
		sm.months as month_name--this will come from concat of years from this table and months scenario_master
    From bronze.fact_pl_grid_ye pg
	Left Join bronze.dim_ebit_direction ed
	On pg.line_description = ed.line_description
	Left Join bronze.dim_scenario_master sm
	On pg.scenario = sm.scenario
	)
	Select
		pack_entity_name,
		line_description,
		custom_1,
		custom_2,
		years,
		scenario,
		view_,
		amount_in_rupees,
		ebit_direction, 
		common_name, 
		category, 
		years || month_name as year_month_name 
	From fact_pl_ye;

--Load data into silver.fact_trial_balance
	If to_regclass('silver.fact_trial_balance') Is Not Null Then
	Truncate Table silver.fact_trial_balance;
	End If;
	Insert Into silver.fact_trial_balance(
		accounting_period,
		ledger,
		entity_code,
		entity_name,
		cost_center,
		cost_center_description,
		account,
		account_description,
		intercompany,
		intercompany_description,
		service_line,
		service_line_description,
		analysis,
		analysis_description,
		future1,
		future1_description,
		future2,
		future2_description,
		beginning_balance,
		period_activity,
		ending_balance,
		statement_map,
		statement_group,
		ce_direction,
		adjustment_items,
		ce_bucket,
		ce_sub_bucket,
		gl_mapping
	)
	Select
		tb.accounting_period,
		tb.ledger,
		tb.entity_code,
		tb.entity_name,
		tb.cost_center,
		tb.cost_center_description,
		tb.account,
		tb.account_description,
		tb.intercompany,
		tb.intercompany_description,
		tb.service_line,
		tb.service_line_description,
		tb.analysis,
		tb.analysis_description,
		tb.future1,
		tb.future1_description,
		tb.future2,
		tb.future2_description,
		tb.beginning_balance,
		tb.period_activity,
		tb.ending_balance,
		gm.statement_map,
		gm.statement_group,
		gm.ce_direction,
		gm.adjustment_items,
		gm.ce_bucket,
		gm.ce_sub_bucket,
		gm.gl_mapping
	From bronze.fact_trial_balance tb
	Left Join bronze.dim_gl_mapping gm
	On tb.account = gm.gl_number;

--Load data into silver.fact_pl_budget

	If to_regclass('silver.fact_pl_budget') Is Not Null Then
	Truncate Table silver.fact_pl_budget;
	End If;
	Insert Into silver.fact_pl_budget(
		pack_entity_name,
		line_description,
		custom_1,
		custom_2,
		years,
		scenario,
		view_,
		amount_in_rupees,
		ebit_direction, --this will come from Left join on dim_ebit_direction
		common_name, --this will come from Left join on dim_ebit_direction
		category, --this will come from Left join on dim_ebit_direction
		year_month_name --this will come from concat of years from this table and months scenario_master
    )
	With fact_pl_budget as(
	Select
		pg.pack_entity_name as pack_entity_name,
		pg.line_description as line_description,
		pg.custom_1 as custom_1,
		pg.custom_2 as custom_2,
		pg.years as years,
		pg.scenario as scenario,
		pg.view_ as view_,
		pg.amount_in_rupees as amount_in_rupees,
		ed.ebit_direction as ebit_direction, 
		ed.common_name as common_name, 
		ed.category as category,
		sm.months as month_name--this will come from concat of years from this table and months scenario_master
    From bronze.fact_pl_budget pg
	Left Join bronze.dim_ebit_direction ed
	On pg.line_description = ed.line_description
	Left Join bronze.dim_scenario_master sm
	On pg.scenario = sm.scenario
	)
	Select
		pack_entity_name,
		line_description,
		custom_1,
		custom_2,
		years,
		scenario,
		view_,
		amount_in_rupees,
		ebit_direction, 
		common_name, 
		category, 
		years || month_name as year_month_name 
	From fact_pl_budget;

--Load data in silver.fact_bs_budget

	If to_regclass('silver.fact_bs_budget') Is Not Null Then
	Truncate Table silver.fact_bs_budget;
	End If;
	Insert Into silver.fact_bs_budget(
		line_description,
		pack_entity_name,
		years,
		scenario,
		months,
		amount_in_rupees,
		ce_direction, --this will come from join with dim_ce_direction
		adjustment_items, --this will come from join with dim_ce_direction
		ce_bucket, --this will come from join with dim_ce_direction
		ce_sub_bucket, --this will come from join with dim_ce_direction
		month_year, --this will be a concatenate of years column from this table and month column from scenario master
		category --this will come from join with dim_ce_direction
	)
	With fact_bs_budget26 as(
	Select
		bg.line_description as line_description,
		bg.pack_entity_name as pack_entity_name,
		bg.years as years,
		bg.scenario as scenario,
		bg.months as months,
		bg.amount_in_rupees as amount_in_rupees,
		cd.ce_direction as ce_direction,
		cd.adjustment_items as adjustment_items, 
		cd.ce_bucket as ce_bucket, 
		cd.ce_sub_bucket as ce_sub_bucket, 
		cd.category as category,
		sm.months as month_name
	From bronze.fact_bs_budget bg
	Left Join bronze.dim_ce_direction cd
	On bg.line_description = cd.line_description
	Left Join bronze.dim_scenario_master sm
	On bg.scenario = sm.scenario
	)
	Select
		line_description,
		pack_entity_name,
		years,
		scenario,
		months, 
		amount_in_rupees, 
		ce_direction, 
		adjustment_items,
		ce_bucket, 
		ce_sub_bucket, 
		years||month_name as month_year, 
		category
	From fact_bs_budget26;

End;
$$;

--============================================================
--call procedure silver.load_silver()
--============================================================

call silver.load_silver()



