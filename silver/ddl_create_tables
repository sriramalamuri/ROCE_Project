--==============================================================

--Create silver.dim_ce_direction

Do $$
Begin
	If to_regclass('silver.dim_ce_direction') Is Not Null Then
	Drop Table silver.dim_ce_direction;
	End If;
End $$;
Create Table silver.dim_ce_direction(
	Order_key int,
	line_description varchar(100),
	ce_direction int,
	adjustment_items int,
	ce_bucket varchar(100),
	ce_sub_bucket varchar(100),
	dwh_create_date timestamp default now()
);

